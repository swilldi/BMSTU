{
    "tasks": [
        {
            "label": "Clean",
            "type": "shell",
            "command": "rm",
            "args": ["-f", "*.exe", "*.o"],
            "detail": "Clean results of build tasks.",
            "group": "build"
        },
        {
            "type": "cppbuild",
            "label": "Build Debug",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-std=c99",
                "-lm",
                "-Wall",
                "-Werror",
                "-O0",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/app.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Building application for debugging",
            "dependsOn": ["Clean"]
        },
        {
            "type": "cppbuild",
            "label": "Build Release",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-std=c99",
                "-lm",
                "-Wall",
                "-Werror",
                "-O2",
                "${file}",
                "-o",
                "${fileDirname}/app.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Building final application",
            "dependsOn": [
                "Clean"
            ]
        },
        {
            "label": "Run debug application",
            "type": "process",
            "command": "app.exe",
            "detail": "Run debug application (without debuger).",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": ["Build Debug"]
        },
        {
            "label": "Run release application",
            "type": "process",
            "command": "app.exe",
            "detail": "Run release application.",
            "problemMatcher": [],
            "group": "none",
            "dependsOn": [
                "Build Release"
            ]
        }

        
    ],
    "version": "2.0.0"
    }